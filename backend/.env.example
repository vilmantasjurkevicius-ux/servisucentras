# Nukopijuokite į .env ir užpildykite tikromis reikšmėmis. .env NIEKADA netalpinamas į Git (žr. .gitignore).

# Lokaliai — fiksuotas portas. Railway/kituose hostinguose PORT nustato pati platforma
# automatiškai — šio kintamojo ten NEBEREIKIA rankiniu būdu vesti.
PORT=3000

# Nebūtina. Kelias iki SQLite DB failo. Palikite tuščią lokaliam vystymui (naudos
# backend/data/servisucentras.db). Railway'uje, jei prijungtas Volume (nuolatinis diskas)
# prie /data, nustatykite DB_PATH=/data/servisucentras.db, kad duomenys išliktų tarp deploy'ų.
DB_PATH=

# PRIVALOMA — serveris nepasileis be šio lauko. Sugeneruokite ilgą atsitiktinį raktą, pvz.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Admin prisijungimo duomenys — naudojami TIK pirmą kartą kuriant DB (seed).
# PRIVALOMA — jei trūksta, serveris nepasileis pirmo paleidimo metu.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Kableliais atskirtas sąrašas domenų/adresų, kuriems leidžiama kviesti šį API iš naršyklės (CORS).
# Vietinei aplinkai — statinio failų serverio adresas (žr. static-server.js, numatytas 5500 portas).
# Railway'uje (ar kitame hostinge) įrašykite ten gautą viešą adresą, pvz.: https://jusu-projektas.up.railway.app
# Nuo šios versijos backend'as pats atiduoda ir HTML puslapius iš to paties domeno, tad realiam
# naršyklės naudojimui šis laukas tapo tik papildoma apsauga, ne būtinybe — bet vis tiek jį užpildykite.
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:3000
